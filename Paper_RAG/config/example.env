# DeepSeek API Key (for LLM)
DEEPSEEK_API_KEY=

ZHIPU_API_KEY=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# MinerU API Key (for PDF parsing)
MINERU_API_KEY=

# MinerU Parsing Mode: "flash" (fast) or "precision" (high accuracy)
# Default: precision for production
MINERU_MODE=precision

# Retrieval Mode: demo (vector only) or full (vector + BM25)
RETRIEVAL_MODE=full
